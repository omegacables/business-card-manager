cat > .gitignore << 'EOF'
# Dependencies
node_modules/

# Environment
.env
.env.local
.env.*.local

# Next.js
.next/
out/

# Build
build/
dist/

# Debug
npm-debug.log*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Google credentials
*-credentials.json
EOF
.vercel
.env*.local
tsconfig.tsbuildinfo
